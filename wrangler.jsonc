{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "immi-website",
  "compatibility_date": "2026-04-03",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "immi-negoce.ma",
      "custom_domain": true
    },
    {
      "pattern": "www.immi-negoce.ma",
      "custom_domain": true
    }
  ]
}
